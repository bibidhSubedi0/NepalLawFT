    {
      "cell_type": "code",
      "source": [
        "# ── 1. CONFIG ────────────────────────────────────────────────\n",
        "MODEL_ID    = \"meta-llama/Meta-Llama-3.1-8B-Instruct\"\n",
        "# MODEL_ID    = \"microsoft/Phi-3-mini-4k-instruct\"\n",
        "OUTPUT_DIR  = \"./nepali-legal-llama\"\n",
        "RANK        = 16\n",
        "ALPHA       = 32\n",
        "LR          = 2e-4\n",
        "EPOCHS      = 1          # 1 for first run, increase after confirming pipeline works\n",
        "MAX_SEQ_LEN = 2048\n",
        "BATCH_SIZE  = 2\n",
        "GRAD_ACCUM  = 8          # effective batch size = 2 × 8 = 16"
      ],
      "metadata": {
        "id": "vG1vdwYtNuOa"
      },
      "id": "vG1vdwYtNuOa",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 2. QUANTIZATION CONFIG ───────────────────────────────────\n",
        "bnb_config = BitsAndBytesConfig(\n",
        "    load_in_4bit=True,\n",
        "    bnb_4bit_quant_type=\"nf4\",\n",
        "    bnb_4bit_compute_dtype=torch.bfloat16,\n",
        "    bnb_4bit_use_double_quant=True,\n",
        ")\n"
      ],
      "metadata": {
        "id": "8wwMTSEtNw4h"
      },
      "id": "8wwMTSEtNw4h",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from huggingface_hub import login\n",
        "login()"
      ],
      "metadata": {
        "id": "iVlrqc_uOsm3"
      },
      "id": "iVlrqc_uOsm3",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 3. LOAD TOKENIZER ────────────────────────────────────────\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_ID)\n",
        "tokenizer.pad_token    = tokenizer.eos_token\n",
        "tokenizer.padding_side = \"right\""
      ],
      "metadata": {
        "id": "Pft-I3QxNx8l"
      },
      "id": "Pft-I3QxNx8l",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 4. LOAD BASE MODEL ───────────────────────────────────────\n",
        "model = AutoModelForCausalLM.from_pretrained(\n",
        "    MODEL_ID,\n",
        "    quantization_config=bnb_config,\n",
        "    device_map=\"auto\",\n",
        ")\n",
        "model.config.use_cache = False"
      ],
      "metadata": {
        "id": "SI7DGCeKNzaS"
      },
      "id": "SI7DGCeKNzaS",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "model.print_trainable_parameters()"
      ],
      "metadata": {
        "id": "8ikWgTjyUATS"
      },
      "id": "8ikWgTjyUATS",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 5. APPLY LORA ────────────────────────────────────────────\n",
        "lora_config = LoraConfig(\n",
        "    r=RANK,\n",
        "    lora_alpha=ALPHA,\n",
        "    target_modules=\"all-linear\",\n",
        "    lora_dropout=0.05,\n",
        "    bias=\"none\",\n",
        "    task_type=TaskType.CAUSAL_LM,\n",
        ")\n",
        "model = get_peft_model(model, lora_config)\n",
        "model.print_trainable_parameters()"
      ],
      "metadata": {
        "id": "8Jfy6FnVP0wh"
      },
      "id": "8Jfy6FnVP0wh",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 6. LOAD DATASET ──────────────────────────────────────────\n",
        "# Expected format: ShareGPT JSON with \"messages\" field\n",
        "# Each example: {\"messages\": [{\"role\": \"system\", ...}, {\"role\": \"user\", ...}, {\"role\": \"assistant\", ...}]}\n",
        "dataset = load_dataset(\"json\", data_files={\n",
        "    \"train\":      \"train.jsonl\",\n",
        "    \"validation\": \"val.jsonl\",\n",
        "})"
      ],
      "metadata": {
        "id": "BbcumXF5P7-x"
      },
      "id": "BbcumXF5P7-x",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(dataset.column_names)"
      ],
      "metadata": {
        "id": "s-k83kavQw_9"
      },
      "id": "s-k83kavQw_9",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 7. FORMAT WITH CHAT TEMPLATE ─────────────────────────────\n",
        "\n",
        "def format_example(example):\n",
        "    messages = [\n",
        "        {\"role\": \"user\", \"content\": example[\"question\"]},\n",
        "        {\"role\": \"assistant\", \"content\": example[\"answer\"]},\n",
        "    ]\n",
        "\n",
        "    return {\n",
        "        \"text\": tokenizer.apply_chat_template(\n",
        "            messages,\n",
        "            tokenize=False,\n",
        "            add_generation_prompt=False,\n",
        "        )\n",
        "    }\n",
        "\n",
        "dataset = dataset.map(format_example)"
      ],
      "metadata": {
        "id": "hv1PEKBjP95B"
      },
      "id": "hv1PEKBjP95B",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 8. TRAINING CONFIG ───────────────────────────────────────\n",
        "sft_config = SFTConfig(\n",
        "    output_dir=OUTPUT_DIR,\n",
        "    num_train_epochs=EPOCHS,\n",
        "    per_device_train_batch_size=BATCH_SIZE,\n",
        "    per_device_eval_batch_size=BATCH_SIZE,\n",
        "    gradient_accumulation_steps=GRAD_ACCUM,\n",
        "    gradient_checkpointing=True,\n",
        "    optim=\"paged_adamw_32bit\",\n",
        "    learning_rate=LR,\n",
        "    lr_scheduler_type=\"cosine\",\n",
        "    warmup_ratio=0.05,\n",
        "    bf16=True,\n",
        "    logging_steps=10,\n",
        "    eval_strategy=\"epoch\",\n",
        "    save_strategy=\"epoch\",\n",
        "    load_best_model_at_end=True,\n",
        "    report_to=\"wandb\",\n",
        "    dataset_text_field=\"text\",\n",
        ")"
      ],
      "metadata": {
        "id": "xJBXELN2P_b7"
      },
      "id": "xJBXELN2P_b7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── 9. TRAIN ─────────────────────────────────────────────────\n",
        "trainer = SFTTrainer(\n",
        "    model=model,\n",
        "    args=sft_config,\n",
        "    train_dataset=dataset[\"train\"],\n",
        "    eval_dataset=dataset[\"validation\"],\n",
        "    processing_class=tokenizer,\n",
        ")\n",
        "\n",
        "trainer.train()\n"
      ],
      "metadata": {
        "id": "IH580oXHQBsK"
      },
      "id": "IH580oXHQBsK",
      "execution_count": null,
