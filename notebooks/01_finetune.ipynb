    },
    {
      "cell_type": "code",
      "source": [
        "# ── 10. SAVE ADAPTER ─────────────────────────────────────────\n",
        "trainer.save_model(f\"{OUTPUT_DIR}/final-adapter\")"
      ],
      "metadata": {
        "id": "SPIxQZ9lQDCH"
      },
